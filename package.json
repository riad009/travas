{
  "name": "travas",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "dev:aqurion-ai": "npm run dev --workspace=apps/aqurion-ai",
    "dev:aqurion-atm": "npm run dev --workspace=apps/aqurion-atm",
    "dev:aqurion-dev": "npm run dev --workspace=apps/aqurion-dev",
    "dev:aqurion-directory": "npm run dev --workspace=apps/aqurion-directory",
    "dev:aqurion-financial": "npm run dev --workspace=apps/aqurion-financial",
    "dev:aqurion-home": "npm run dev --workspace=apps/aqurion-home",
    "dev:aqurion-hospitality": "npm run dev --workspace=apps/aqurion-hospitality",
    "dev:aqurion-marketing": "npm run dev --workspace=apps/aqurion-marketing",
    "dev:aqurion-ps": "npm run dev --workspace=apps/aqurion-ps",
    "dev:aqurion-sa": "npm run dev --workspace=apps/aqurion-sa",
    "dev:aqurion-sales": "npm run dev --workspace=apps/aqurion-sales",
    "dev:aqurion-services": "npm run dev --workspace=apps/aqurion-services",
    "dev:aqurion-stores": "npm run dev --workspace=apps/aqurion-stores",
    "dev:aqurion-travel": "npm run dev --workspace=apps/aqurion-travel",
    "dev:coming-soon": "npm run dev --workspace=apps/coming-soon",
    "dev:docs": "npm run dev --workspace=apps/docs",
    "dev:travis-profile": "npm run dev --workspace=apps/travis-profile",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:all": "npm-run-all --parallel dev:aqurion-ai dev:aqurion-atm dev:aqurion-dev dev:aqurion-directory dev:aqurion-financial dev:aqurion-home dev:aqurion-hospitality dev:aqurion-marketing dev:aqurion-ps dev:aqurion-sa dev:aqurion-sales dev:aqurion-services dev:aqurion-stores dev:aqurion-travel dev:coming-soon dev:docs dev:travis-profile dev:web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "turbo": "^2.9.4",
    "typescript": "5.9.2"
  },
  "packageManager": "npm@10.8.3",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
